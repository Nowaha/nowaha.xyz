{
    "name": "nowaha.xyz",
    "version": "1.0.0",
    "main": "index.js",
    "author": "noah@nowaha.xyz",
    "license": "MIT",
    "scripts": {
        "clean": "rimraf ./out",
        "format": "prettier --config .prettierrc --write .",
        "format:check": "prettier --config .prettierrc --check .",
        "build": "yarn clean && run-s build:static build:ts build:css",
        "watch": "run-p watch:static watch:ts watch:css",
        "build:static": "node scripts/build-static.js",
        "watch:static": "node scripts/build-static.js --watch",
        "build:ts": "tsc",
        "watch:ts": "tsc --watch",
        "build:css": "tailwindcss -i ./public/css/index.css -o ./out/public/css/index.css",
        "watch:css": "tailwindcss -i ./public/css/index.css -o ./out/public/css/index.css --watch"
    },
    "devDependencies": {
        "@catppuccin/tailwindcss": "^1.0.0",
        "@eslint/js": "^10.0.1",
        "@tailwindcss/cli": "^4.3.0",
        "chokidar": "^5.0.0",
        "eslint": "^10.4.1",
        "globals": "^17.6.0",
        "npm-run-all2": "^9.0.1",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0"
    }
}
